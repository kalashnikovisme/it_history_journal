FROM ruby:3.3-slim

WORKDIR /app

RUN apt-get update -qq \
  && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    ca-certificates \
    ffmpeg \
    nodejs \
    npm \
    fonts-liberation \
    fonts-open-sans \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g playwright \
  && playwright install chromium --with-deps \
  && rm -rf /var/lib/apt/lists/*

CMD ["sleep", "infinity"]
