!!! 5
%html
  %head
    %meta{charset: 'utf-8'}
    %title IT History Journal
    - if jsonld_json
      %script{type: 'application/ld+json'}
        != jsonld_json
    :javascript
      (function() {
        var lang = navigator.language || navigator.userLanguage || 'en';
        window.location.replace(lang.toLowerCase().startsWith('ru') ? '/ru/' : '/en/');
      })();
    %noscript
      %meta{'http-equiv' => 'refresh', content: '0; url=/en/'}
  %body
    %p
      %a{href: '/en/'} IT History Journal
