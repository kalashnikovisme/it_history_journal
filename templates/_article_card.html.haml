%article.bg-card.rounded-xl.overflow-hidden.group
  %a.flex.items-start{href: article.url}
    - if article.cover?
      .shrink-0.w-24.h-24.overflow-hidden
        %img.w-full.h-full.object-cover{src: article.cover_url, alt: ''}
    .flex.items-start.justify-between.gap-3.p-4.flex-1.min-w-0
      .flex-1.min-w-0
        %h3.font-semibold.text-white.text-sm.leading-snug.mb-1.group-hover:text-accent.transition-colors
          = article.title
        %p.text-white-55.text-xs.leading-relaxed.line-clamp-2
          = article.excerpt
      .shrink-0.text-right
        %span.inline-block.bg-accent-dim.text-accent.text-xs.font-medium.rounded.px-2.py-1.whitespace-nowrap
          = article.date_label
