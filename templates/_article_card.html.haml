- link_cls     = 'flex items-stretch md:p-3 gap-3'
- img_wrap_cls = 'shrink-0 w-20 h-20 overflow-hidden md:w-28 md:h-28'
- title_cls    = featured ? 'text-base' : 'text-sm'
- excerpt_cls  = featured ? 'text-sm' : 'text-xs'

%article.bg-card.rounded-xl.overflow-hidden.group.hover:bg-raised.transition-colors{'aria-label': article.title}
  %a{class: link_cls, href: article.url}
    - if article.cover?
      %div{class: img_wrap_cls}
        %img.w-full.h-full.object-cover{src: article.thumb_url, alt: ''}
    .flex.flex-col.flex-1.min-w-0
      .flex.items-start.justify-between.gap-2
        %h3{class: "font-semibold text-white #{title_cls} leading-snug line-clamp-2 group-hover:text-accent transition-colors flex-1 min-w-0"}
          = article.title
        %span.hidden.md:inline-block.bg-accent-dim.text-accent.text-xs.font-medium.rounded.px-2.py-1.whitespace-nowrap.shrink-0
          = article.date_label
      %p{class: "text-white-55 #{excerpt_cls} truncate md:whitespace-normal md:overflow-visible leading-relaxed line-clamp-1 block mt-1"}
        = article.excerpt
