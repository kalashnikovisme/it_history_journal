%article.bg-white.rounded-xl.border.border-gray-100.hover:border-purple-200.transition-colors.group
  %a.flex.items-start.gap-4.p-4{href: article.url}
    .flex-1.min-w-0
      %h3.font-semibold.text-gray-900.text-sm.leading-snug.mb-1.group-hover:text-purple-700.transition-colors
        = article.title
      %p.text-gray-500.text-xs.leading-relaxed.line-clamp-2
        = article.excerpt
    .shrink-0.text-right
      %span.inline-block.bg-purple-50.text-purple-700.text-xs.font-medium.rounded.px-2.py-1.whitespace-nowrap
        = article.date_label
