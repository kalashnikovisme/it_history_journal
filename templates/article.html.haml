.grid.grid-cols-1.lg:grid-cols-3.gap-8
  %article.lg:col-span-2{'aria-label': article.title}
    %header.mb-8
      %span.inline-block.bg-accent-dim.text-accent.text-sm.font-medium.rounded-lg.px-3.py-1.mb-4
        = article.date_label
      %h1.text-2xl.sm:text-3xl.font-bold.text-white.leading-tight.mb-2
        = article.title
      - if article.date
        %p.text-white-35.text-sm
          = article.date

    - if article.cover?
      .mb-8.rounded-2xl.overflow-hidden
        %img.w-full.object-cover{src: article.cover_url, alt: article.title}

    .prose.prose-zinc.prose-invert.prose-sm.sm:prose-base.max-w-none
      != article.content_html

    - unless article.key_facts.empty?
      %section.mt-8.pt-6.border-t.border-white-10{'aria-label': t[:key_facts]}
        %h2.text-lg.font-semibold.text-white.mb-4
          = t[:key_facts]
        %dl.grid.grid-cols-1.sm:grid-cols-2.gap-4
          - article.key_facts.each do |label, value|
            .rounded-lg.bg-card.border.border-white-10.p-4
              %dt.text-xs.font-semibold.text-white-35.uppercase.tracking-widest.mb-2
                = label
              %dd.text-sm.text-white.leading-relaxed
                = value

    - unless article.sources.empty?
      %section.mt-8.pt-6.border-t.border-white-10{'aria-label': t[:sources]}
        %h2.text-lg.font-semibold.text-white.mb-4
          = t[:sources]
        %ol.list-decimal.list-inside.space-y-2.text-sm.text-white-60
          - article.sources.each do |source|
            %li
              %a.text-accent-muted.hover:text-accent.transition-colors{href: source['url'], target: '_blank', rel: 'noopener noreferrer'}
                = source['title']

    - if article.author
      .mt-8.pt-6.border-t.border-white-10
        %p.text-white-35.text-sm
          = article.author

    != partial('support', lang: lang, t: t, article_slug: article.slug)

  .lg:col-span-1
    .sticky.top-20.flex.flex-col.gap-6
      != partial('social_widget', {lang: lang, t: t})

      - unless related.empty?
        %aside{'aria-label': t[:related_posts]}
          %h2.text-xs.font-semibold.text-white-35.uppercase.tracking-widest.mb-4
            = t[:related_posts]
          .flex.flex-col.gap-3
            - related.each do |art|
              != partial('article_card', article: art, t: t, featured: false)

      - unless popular.empty?
        %aside{'aria-label': t[:popular_posts]}
          %h2.text-xs.font-semibold.text-white-35.uppercase.tracking-widest.mb-4
            = t[:popular_posts]
          .flex.flex-col.gap-3
            - popular.each do |art|
              != partial('article_card', article: art, t: t, featured: false)
