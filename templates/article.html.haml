.grid.grid-cols-1.lg:grid-cols-3.gap-8
  %article.lg:col-span-2{'aria-label': article.title}
    %header.mb-8
      %span.inline-block.bg-accent-dim.text-accent.text-sm.font-medium.rounded-lg.px-3.py-1.mb-4
        = article.date_label
      %h1.text-2xl.sm:text-3xl.font-bold.text-white.leading-tight.mb-2
        = article.title
      - if article.date
        %p.text-white-35.text-sm
          = article.date

    - if article.cover?
      .mb-8.rounded-2xl.overflow-hidden
        %img.w-full.object-cover{src: article.cover_url, alt: article.title}

    .prose.prose-zinc.prose-invert.prose-sm.sm:prose-base.max-w-none
      != article.content_html

  .lg:col-span-1
    .sticky.top-20.flex.flex-col.gap-6

      - unless related.empty?
        %aside{'aria-label': t[:related_posts]}
          %h2.text-xs.font-semibold.text-white-35.uppercase.tracking-widest.mb-4
            = t[:related_posts]
          .flex.flex-col.gap-3
            - related.each do |art|
              != partial('article_card', article: art, t: t, featured: false)

      - unless popular.empty?
        %aside{'aria-label': t[:popular_posts]}
          %h2.text-xs.font-semibold.text-white-35.uppercase.tracking-widest.mb-4
            = t[:popular_posts]
          .flex.flex-col.gap-3
            - popular.each do |art|
              != partial('article_card', article: art, t: t, featured: false)
