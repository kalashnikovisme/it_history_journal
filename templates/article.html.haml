.grid.grid-cols-1.lg:grid-cols-3.gap-8
  %article.lg:col-span-2
    %header.mb-8
      %span.inline-block.bg-purple-50.text-purple-700.text-sm.font-medium.rounded-lg.px-3.py-1.mb-4
        = article.date_label
      %h1.text-3xl.font-bold.text-gray-900.leading-tight.mb-2
        = article.title
      - if article.date
        %p.text-gray-400.text-sm
          = article.date

    .prose.prose-gray.prose-sm.sm:prose-base.max-w-none
      != article.content_html

  .lg:col-span-1
    .sticky.top-20.flex.flex-col.gap-6

      - unless related.empty?
        %aside
          %h2.text-xs.font-semibold.text-gray-400.uppercase.tracking-widest.mb-4
            = t[:related_posts]
          .flex.flex-col.gap-3
            - related.each do |art|
              != partial('article_card', article: art, t: t)

      - unless popular.empty?
        %aside
          %h2.text-xs.font-semibold.text-gray-400.uppercase.tracking-widest.mb-4
            = t[:popular_posts]
          .flex.flex-col.gap-3
            - popular.each do |art|
              != partial('article_card', article: art, t: t)
