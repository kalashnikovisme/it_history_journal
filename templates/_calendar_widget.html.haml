- month_name = t[:months][current_month - 1]
- days_in_month = Date.new(current_year, current_month, -1).day
- first_dow = Date.new(current_year, current_month, 1).wday
.bg-card.rounded-xl.p-4
  .flex.items-center.justify-between.mb-3
    %h3.text-sm.font-semibold.text-white
      = "#{month_name} #{current_year}"
    %a.text-xs.text-accent-muted.hover:text-accent.transition-colors{href: "/#{lang}/calendar/"}
      = t[:calendar] + " →"
  .grid.grid-cols-7.gap-px.text-center.mb-1
    - %w[Su Mo Tu We Th Fr Sa].each do |d|
      %span.text-xs.text-white-30.font-medium= d
  .grid.grid-cols-7.gap-px.text-center
    - first_dow.times do
      %span
    - (1..days_in_month).each do |d|
      - article_url = days_with_articles[[current_month, d]]
      - is_today = d == current_day
      - if article_url
        %a.block.w-full.aspect-square.flex.items-center.justify-center.rounded.text-xs.font-medium.bg-accent-dim.text-accent.hover:bg-accent-high.transition-colors{href: article_url, class: is_today ? 'ring-1 ring-accent' : ''}
          = d
      - elsif is_today
        %span.block.w-full.aspect-square.flex.items-center.justify-center.rounded.text-xs.bg-accent.text-page.font-semibold
          = d
      - else
        %span.block.w-full.aspect-square.flex.items-center.justify-center.rounded.text-xs.text-white-20
          = d
