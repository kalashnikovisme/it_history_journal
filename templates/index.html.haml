- if latest
  %section.mb-10
    %p.text-xs.font-semibold.text-purple-700.uppercase.tracking-widest.mb-3
      = t[:latest_post]
    %a.block.bg-white.rounded-2xl.border.border-gray-100.hover:border-purple-200.transition-all.p-6.group{href: latest.url}
      .flex.items-start.justify-between.gap-6
        .flex-1.min-w-0
          %h2.text-2xl.font-bold.text-gray-900.leading-tight.mb-3.group-hover:text-purple-700.transition-colors
            = latest.title
          %p.text-gray-500.leading-relaxed.line-clamp-3
            = latest.excerpt
        .shrink-0
          %span.inline-block.bg-purple-50.text-purple-700.text-sm.font-medium.rounded-lg.px-3.py-1.whitespace-nowrap
            = latest.date_label

- cal_locals = {lang: lang, t: t, days_with_articles: days_with_articles, current_month: current_month, current_year: current_year, current_day: current_day}

.grid.grid-cols-1.lg:grid-cols-3.gap-8
  .lg:col-span-2
    %section.mb-10
      %h2.text-xs.font-semibold.text-gray-400.uppercase.tracking-widest.mb-4
        = t[:recent_posts]
      .flex.flex-col.gap-3
        - recent.each do |art|
          != partial('article_card', article: art, t: t)

  .lg:col-span-1
    .sticky.top-20.flex.flex-col.gap-6
      != partial('calendar_widget', cal_locals)

      - unless popular.empty?
        %section
          %h2.text-xs.font-semibold.text-gray-400.uppercase.tracking-widest.mb-4
            = t[:popular_posts]
          .flex.flex-col.gap-3
            - popular.first(5).each do |art|
              != partial('article_card', article: art, t: t)
