- if latest
  %section.mb-10
    %p.text-xs.font-semibold.text-accent-muted.uppercase.tracking-widest.mb-3
      = t[:latest_post]
    %a.flex.flex-col.lg:flex-row-reverse.lg:items-stretch.bg-card.rounded-2xl.overflow-hidden.group{href: latest.url}
      - if latest.cover?
        .w-full.h-44.lg:h-auto.lg:shrink-0.lg:w-72.overflow-hidden
          %img.w-full.h-full.object-cover{src: latest.cover_url, alt: ''}
      .flex.items-start.justify-between.gap-4.p-4.sm:gap-6.sm:p-6.flex-1.min-w-0
        .flex-1.min-w-0
          %h2.text-xl.sm:text-2xl.font-bold.text-white.leading-tight.mb-3.group-hover:text-accent.transition-colors
            = latest.title
          %p.text-white-55.leading-relaxed.line-clamp-3
            = latest.excerpt
        .shrink-0
          %span.inline-block.bg-accent-dim.text-accent.text-sm.font-medium.rounded-lg.px-3.py-1.whitespace-nowrap
            = latest.date_label

- cal_locals = {lang: lang, t: t, days_with_articles: days_with_articles, current_month: current_month, current_year: current_year, current_day: current_day}

.grid.grid-cols-1.lg:grid-cols-3.gap-8
  .lg:col-span-2
    %section.mb-10
      .flex.items-center.justify-between.mb-4
        %h2.text-xs.font-semibold.text-white-35.uppercase.tracking-widest
          = t[:recent_posts]
        %a.text-xs.text-accent-muted.hover:text-accent.transition-colors{href: "/#{lang}/articles/"}
          = "#{t[:all_articles]} →"
      .flex.flex-col.gap-3
        - recent.each do |art|
          != partial('article_card', article: art, t: t, featured: true)
      %a.block.w-full.text-center.mt-4.py-3.rounded-xl.text-sm.font-medium.text-accent-muted.border.border-white-10.hover:border-white-20.hover:text-white.transition-colors{href: "/#{lang}/articles/"}
        = t[:more]

  .lg:col-span-1
    .sticky.top-20.flex.flex-col.gap-6
      != partial('calendar_widget', cal_locals)

      - unless popular.empty?
        %section
          %h2.text-xs.font-semibold.text-white-35.uppercase.tracking-widest.mb-4
            = t[:popular_posts]
          .flex.flex-col.gap-3
            - popular.first(5).each do |art|
              != partial('article_card', article: art, t: t, featured: false)
