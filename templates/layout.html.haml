!!! 5
%html{lang: lang}
  %head
    %meta{charset: 'utf-8'}
    %meta{name: 'viewport', content: 'width=device-width, initial-scale=1'}
    %title= title
    %link{rel: 'stylesheet', href: '/assets/css/output.css'}
    %link{rel: 'preconnect', href: 'https://fonts.googleapis.com'}
    %link{rel: 'preconnect', href: 'https://fonts.gstatic.com', crossorigin: true}
    %link{rel: 'stylesheet', href: 'https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap'}
  %body.bg-stone-50.font-sans.text-gray-900.min-h-screen
    %header.bg-white.border-b.border-gray-100.sticky.top-0.z-50
      .max-w-5xl.mx-auto.px-4.sm:px-6.h-14.flex.items-center.justify-between
        %a.flex.items-center.gap-2.group{href: "/#{lang}/"}
          .w-8.h-8.rounded-full.bg-gray-900.flex.items-center.justify-center.shrink-0
            %span.text-white.text-xs.font-bold.tracking-tight ITH
          %span.font-semibold.text-gray-900.text-base.group-hover:text-purple-700.transition-colors
            = t[:site_name]
        %nav.flex.items-center.gap-5
          %a.hidden.sm:block.text-sm.text-gray-500.hover:text-gray-900.transition-colors{href: "/#{lang}/"}
            = t[:home]
          %a.hidden.sm:block.text-sm.text-gray-500.hover:text-gray-900.transition-colors{href: "/#{lang}/calendar/"}
            = t[:calendar]
          %a.text-sm.font-medium.text-purple-700.hover:text-purple-900.border.border-purple-200.rounded.px-2.py-0.5.transition-colors{href: "/#{lang == 'en' ? 'ru' : 'en'}/"}
            = t[:lang_switch]
    %main.max-w-5xl.mx-auto.px-4.sm:px-6.py-8
      != content
    %footer.border-t.border-gray-100.mt-16
      .max-w-5xl.mx-auto.px-4.sm:px-6.py-8.flex.items-center.justify-between.text-sm.text-gray-400
        %span
          = "© #{year} IT History Journal"
        .flex.items-center.gap-4
          %a.hover:text-gray-600.transition-colors{href: "/en/"} EN
          %a.hover:text-gray-600.transition-colors{href: "/ru/"} RU
