!!! 5
%html{lang: lang}
  %head
    %meta{charset: 'utf-8'}
    %meta{name: 'viewport', content: 'width=device-width, initial-scale=1'}
    %title= title
    %link{rel: 'icon', href: '/favicon.ico', sizes: '32x32'}
    %link{rel: 'icon', href: '/icon.svg', type: 'image/svg+xml'}
    %link{rel: 'apple-touch-icon', href: '/apple-touch-icon.png'}
    - if canonical_url
      %link{rel: 'canonical', href: canonical_url}
    - alternates.each do |alternate|
      %link{rel: 'alternate', hreflang: alternate[:lang], href: alternate[:url]}
    - if alternates.any?
      - default_alternate = alternates.find { |alternate| alternate[:lang] == 'en' } || alternates.first
      %link{rel: 'alternate', hreflang: 'x-default', href: default_alternate[:url]}
    - css_href = css_ver ? "/assets/css/output.css?v=#{css_ver}" : '/assets/css/output.css'
    %link{rel: 'stylesheet', href: css_href}
    - if og
      %meta{property: 'og:type', content: 'article'}
      %meta{property: 'og:title', content: og[:title]}
      %meta{property: 'og:description', content: og[:description]}
      %meta{property: 'og:url', content: og[:url]}
      - if og[:image]
        %meta{property: 'og:image', content: og[:image]}
      %meta{name: 'twitter:card', content: og[:image] ? 'summary_large_image' : 'summary'}
      %meta{name: 'twitter:title', content: 'IT History Journal'}
      %meta{name: 'twitter:description', content: og[:description]}
      - if og[:image]
        %meta{name: 'twitter:image', content: og[:image]}
    %link{rel: 'preconnect', href: 'https://fonts.googleapis.com'}
    %link{rel: 'preconnect', href: 'https://fonts.gstatic.com', crossorigin: true}
    %link{rel: 'stylesheet', href: 'https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap'}
    %link{rel: 'alternate', type: 'application/rss+xml', title: t[:site_name], href: "/#{lang}/feed.xml"}
    - if jsonld_json
      %script{type: 'application/ld+json'}
        != jsonld_json
    %script{async: true, src: 'https://www.googletagmanager.com/gtag/js?id=G-3CL3840NT7'}
    :javascript
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3CL3840NT7');
  %body.bg-page.font-sans.text-white.min-h-screen
    %header.bg-card.border-b.border-white-10.sticky.top-0.z-50
      .max-w-5xl.mx-auto.px-4.sm:px-6.h-14.flex.items-center.justify-between
        .flex.items-center.gap-3
          %button#nav-open.sm:hidden.flex.items-center.justify-center.text-white-60.hover:text-white.transition-colors.p-1{type: 'button', 'aria-label': 'Open menu'}
            %svg.w-6.h-6{fill: 'none', stroke: 'currentColor', 'stroke-width': '2', 'stroke-linecap': 'round', viewBox: '0 0 24 24', 'aria-hidden': 'true'}
              %path{d: 'M4 6h16M4 12h16M4 18h16'}
          %a.flex.items-center.gap-2.group{href: "/#{lang}/"}
            %img.w-8.h-8.rounded-full.shrink-0{src: '/icon.svg', alt: '', aria: {hidden: 'true'}}
            %span.font-semibold.text-white.text-base.group-hover:text-accent.transition-colors
              = t[:site_name]
        %nav.flex.items-center.gap-3.sm:gap-5{'aria-label': t[:nav_label]}
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "/#{lang}/"}
            = t[:home]
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "/#{lang}/articles/"}
            = t[:all_articles]
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "/#{lang}/calendar/"}
            = t[:calendar]
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "/#{lang}/feed.xml", title: 'RSS feed'}
            RSS
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "https://patreon.com/cw/kalashnikovisme", target: "_blank", rel: "noopener noreferrer", onclick: "gtag('event','support_click',{platform:'patreon',location:'navbar',article_slug:document.location.pathname})"}
            Patreon
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "https://boosty.to/kalashnikovisme", target: "_blank", rel: "noopener noreferrer", onclick: "gtag('event','support_click',{platform:'boosty',location:'navbar',article_slug:document.location.pathname})"}
            Boosty
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "https://paypal.me/kalashnikovisme", target: "_blank", rel: "noopener noreferrer", onclick: "gtag('event','support_click',{platform:'paypal',location:'navbar',article_slug:document.location.pathname})"}
            PayPal
          - if lang == 'ru'
