!!! 5
%html{lang: lang}
  %head
    %meta{charset: 'utf-8'}
    %meta{name: 'viewport', content: 'width=device-width, initial-scale=1'}
    %title= title
    %link{rel: 'stylesheet', href: '/assets/css/output.css'}
    %link{rel: 'preconnect', href: 'https://fonts.googleapis.com'}
    %link{rel: 'preconnect', href: 'https://fonts.gstatic.com', crossorigin: true}
    %link{rel: 'stylesheet', href: 'https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap'}
  %body.bg-page.font-sans.text-white.min-h-screen
    %header.bg-card.border-b.border-white-10.sticky.top-0.z-50
      .max-w-5xl.mx-auto.px-4.sm:px-6.h-14.flex.items-center.justify-between
        %a.flex.items-center.gap-2.group{href: "/#{lang}/"}
          .w-8.h-8.rounded-full.bg-accent-dim.flex.items-center.justify-center.shrink-0
            %span.text-accent.text-xs.font-bold.tracking-tight ITH
          %span.font-semibold.text-white.text-base.group-hover:text-accent.transition-colors
            = t[:site_name]
        %nav.flex.items-center.gap-3.sm:gap-5
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "/#{lang}/"}
            = t[:home]
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "/#{lang}/articles/"}
            = t[:all_articles]
          %a.text-sm.text-white-60.hover:text-white.transition-colors{href: "/#{lang}/calendar/"}
            = t[:calendar]
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "https://patreon.com/cw/kalashnikovisme", target: "_blank", rel: "noopener noreferrer"}
            Patreon
          %a.hidden.sm:block.text-sm.text-white-60.hover:text-white.transition-colors{href: "https://boosty.to/kalashnikovisme", target: "_blank", rel: "noopener noreferrer"}
            Boosty
          %a.text-sm.font-medium.text-accent-muted.hover:text-accent.border.border-white-20.rounded.px-2.py-0.5.transition-colors{href: "/#{lang == 'en' ? 'ru' : 'en'}/"}
            = t[:lang_switch]
    %main.max-w-5xl.mx-auto.px-4.sm:px-6.py-8
      != content
    %footer.border-t.border-white-10.mt-16
      .max-w-5xl.mx-auto.px-4.sm:px-6.py-8.flex.flex-col.gap-3.sm:flex-row.items-start.sm:items-center.sm:justify-between.text-sm.text-white-30
        %span
          = "© #{year} IT History Journal"
        .flex.items-center.gap-4
          %a.hover:text-white-60.transition-colors{href: "https://patreon.com/cw/kalashnikovisme", target: "_blank", rel: "noopener noreferrer"} Patreon
          %a.hover:text-white-60.transition-colors{href: "https://boosty.to/kalashnikovisme", target: "_blank", rel: "noopener noreferrer"} Boosty
          %a.hover:text-white-60.transition-colors{href: "/en/"} EN
          %a.hover:text-white-60.transition-colors{href: "/ru/"} RU
