            PayPal
          - if lang == 'ru'
            %a.block.py-3.px-3.text-lg.text-white-60.hover:text-white.hover:bg-raised.rounded-xl.transition-colors{href: 'https://t.me/it_history_journal', target: '_blank', rel: 'noopener noreferrer'}
              Telegram
          .my-2.border-t.border-white-10
          %a.block.py-3.px-3.text-lg.font-medium.text-accent-muted.hover:text-accent.hover:bg-raised.rounded-xl.transition-colors{href: "/#{lang == 'en' ? 'ru' : 'en'}/"}
            = t[:lang_switch]
        .p-4.border-t.border-white-10
          %button#nav-close.flex.items-center.justify-center.gap-2.w-full.bg-raised.hover:bg-accent-dim.text-white.font-semibold.py-5.text-xl.rounded-xl.transition-colors{type: 'button'}
            %svg.w-6.h-6{fill: 'none', stroke: 'currentColor', 'stroke-width': '2', 'stroke-linecap': 'round', 'stroke-linejoin': 'round', viewBox: '0 0 24 24', 'aria-hidden': 'true'}
              %path{d: 'M6 18L18 6M6 6l12 12'}
            = t[:close_menu]
    %main.max-w-5xl.mx-auto.px-4.sm:px-6.py-8
      != content
    :javascript
      (function () {
        var d = new Date();
        var key = (d.getMonth() + 1) + '-' + d.getDate();
        var found = false;
        document.querySelectorAll('[data-today-key]').forEach(function (el) {
          if (el.getAttribute('data-today-key') === key) {
            el.classList.remove('hidden');
            found = true;
          }
        });
        if (!found) {
          var fb = document.getElementById('today-fallback');
          if (fb) fb.classList.remove('hidden');
        } else {
          document.querySelectorAll('[data-recent-key="' + key + '"]').forEach(function (el) {
            el.classList.add('hidden');
          });
        }
      })();
    :javascript
      (function () {
        var d = new Date();
        var key = (d.getMonth() + 1) + '-' + d.getDate();
        document.querySelectorAll('[data-cal-day="' + key + '"]').forEach(function (el) {
          if (el.tagName === 'A') {
            el.classList.add('ring-1', 'ring-accent');
          } else {
            el.classList.remove('text-white-20');
            el.classList.add('bg-accent', 'text-page', 'font-semibold');
          }
        });
      })();
    :javascript
      (function() {
        var open = document.getElementById('nav-open');
        if (!open) return;
        var nav = document.getElementById('mobile-nav');
        var drawer = document.getElementById('mobile-drawer');
        var backdrop = document.getElementById('mobile-backdrop');
        function openMenu() {
          nav.classList.remove('hidden');
          requestAnimationFrame(function() {
            drawer.classList.remove('-translate-x-full');
            drawer.classList.add('translate-x-0');
            backdrop.classList.remove('opacity-0');
            backdrop.classList.add('opacity-60');
          });
          document.body.style.overflow = 'hidden';
        }
        function closeMenu() {
          drawer.classList.add('-translate-x-full');
          drawer.classList.remove('translate-x-0');
          backdrop.classList.add('opacity-0');
          backdrop.classList.remove('opacity-60');
          document.body.style.overflow = '';
          setTimeout(function() { nav.classList.add('hidden'); }, 300);
        }
        open.addEventListener('click', openMenu);
        document.getElementById('nav-close').addEventListener('click', closeMenu);
        backdrop.addEventListener('click', closeMenu);
        document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeMenu(); });
      })();
