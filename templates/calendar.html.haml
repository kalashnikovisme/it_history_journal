%h1.text-2xl.font-bold.text-gray-900.mb-8
  = t[:calendar]

- today = Date.today
- year  = today.year

.grid.grid-cols-1.sm:grid-cols-2.lg:grid-cols-3.gap-6
  - (1..12).each do |m|
    - month_name      = t[:months][m - 1]
    - days_in_month   = Date.new(year, m, -1).day
    - first_dow       = Date.new(year, m, 1).wday
    - has_any         = articles_by_month_day.keys.any? { |k| k[0] == m }

    .bg-white.rounded-xl.border.border-gray-100.p-4
      %h2.text-sm.font-semibold.text-gray-900.mb-3
        = month_name
      .grid.grid-cols-7.gap-px.text-center.mb-1
        - %w[S M T W T F S].each do |d|
          %span.text-xs.text-gray-400= d
      .grid.grid-cols-7.gap-px.text-center
        - first_dow.times do
          %span
        - (1..days_in_month).each do |d|
          - article_url = articles_by_month_day[[m, d]]&.first&.url
          - is_today = (m == today.month && d == today.day)
          - if article_url
            %a.block.w-full.aspect-square.flex.items-center.justify-center.rounded.text-xs.font-medium.bg-purple-100.text-purple-700.hover:bg-purple-200.transition-colors{href: article_url, class: is_today ? 'ring-2 ring-purple-400' : ''}
              = d
          - elsif is_today
            %span.block.w-full.aspect-square.flex.items-center.justify-center.rounded.text-xs.bg-gray-900.text-white.font-semibold
              = d
          - else
            %span.block.w-full.aspect-square.flex.items-center.justify-center.rounded.text-xs.text-gray-300
              = d
