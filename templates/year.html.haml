.flex.items-center.justify-between.mb-8
  %h1.text-2xl.font-bold.text-white= year
  %a.text-sm.text-accent-muted.hover:text-accent.transition-colors{href: "/#{lang}/"}
    ← #{t[:home]}

- if articles.empty?
  .py-16.text-center
    %p.text-white-35.text-lg= t[:no_articles_this_year]
- else
  .flex.flex-col.gap-3
    - articles.each do |art|
      != partial('article_card', article: art, t: t, featured: true)
