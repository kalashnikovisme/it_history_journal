- _sidebar = defined?(context) && context == 'sidebar'
- _slug = defined?(article_slug) ? article_slug.to_s : ''
- _heading = _sidebar ? t[:support_heading_home] : t[:support_heading]
- _body    = _sidebar ? t[:support_body_home]    : t[:support_body]
%section{'aria-label': _heading, class: _sidebar ? nil : 'mt-10 pt-8 border-t border-white-10'}
  .rounded-2xl.bg-raised.border.border-white-10.p-6.sm:p-8
    - unless _sidebar
      %h2.text-base.font-semibold.text-white.mb-2
        = _heading
    %p.text-sm.text-white-60.leading-relaxed.mb-6
      = _body
    .flex.flex-wrap.gap-3
      %a.inline-flex.items-center.gap-2.bg-accent-dim.text-accent.font-medium.text-sm.rounded-lg.px-5.py-2.hover:bg-accent.hover:text-page.transition-colors{href: 'https://patreon.com/cw/kalashnikovisme', target: '_blank', rel: 'noopener noreferrer', onclick: "gtag('event','support_click',{platform:'patreon',location:'article',article_slug:'#{_slug}'})"}
        %svg.w-4.h-4{'aria-hidden': 'true', viewBox: '0 0 24 24', fill: 'currentColor', xmlns: 'http://www.w3.org/2000/svg'}
          %path{d: 'M22.957 7.21c-.004-3.064-2.391-5.576-5.191-6.482-3.478-1.125-8.064-.962-11.384.604C2.357 3.231 1.093 7.391 1.046 11.54c-.039 3.411.302 12.396 5.369 12.46 3.765.047 4.326-4.804 6.068-7.141 1.24-1.662 2.836-2.132 4.801-2.618 3.376-.836 5.678-3.501 5.673-7.031Z'}
        = t[:support_patreon]
      - if lang == 'ru'
        %a.inline-flex.items-center.gap-2.bg-accent-dim.text-accent.font-medium.text-sm.rounded-lg.px-5.py-2.hover:bg-accent.hover:text-page.transition-colors{href: 'https://boosty.to/kalashnikovisme', target: '_blank', rel: 'noopener noreferrer', onclick: "gtag('event','support_click',{platform:'boosty',location:'article',article_slug:'#{_slug}'})"}
          %svg.w-4.h-4{'aria-hidden': 'true', viewBox: '0 0 24 24', fill: 'currentColor', xmlns: 'http://www.w3.org/2000/svg'}
            %path{d: 'M2.661 14.337 6.801 0h6.362L11.88 4.444l-.038.077-3.378 11.733h3.15c-1.321 3.289-2.35 5.867-3.086 7.733-5.816-.063-7.442-4.228-6.02-9.155M8.554 24l7.67-11.035h-3.25l2.83-7.073c4.852.508 7.137 4.33 5.791 8.952C20.16 19.81 14.344 24 8.68 24h-.127z'}
          = t[:support_boosty]
      %a.inline-flex.items-center.gap-2.bg-accent-dim.text-accent.font-medium.text-sm.rounded-lg.px-5.py-2.hover:bg-accent.hover:text-page.transition-colors{href: 'https://paypal.me/kalashnikovisme', target: '_blank', rel: 'noopener noreferrer', onclick: "gtag('event','support_click',{platform:'paypal',location:'article',article_slug:'#{_slug}'})"}
        %svg.w-4.h-4{'aria-hidden': 'true', viewBox: '0 0 24 24', fill: 'currentColor', xmlns: 'http://www.w3.org/2000/svg'}
          %path{d: 'M15.607 4.653H8.941L6.645 19.251H1.82L4.862 0h7.995c3.754 0 6.375 2.294 6.473 5.513-.648-.478-2.105-.86-3.722-.86m6.57 5.546c0 3.41-3.01 6.853-6.958 6.853h-2.493L11.595 24H6.74l1.845-11.538h3.592c4.208 0 7.346-3.634 7.153-6.949a5.24 5.24 0 0 1 2.848 4.686M9.653 5.546h6.408c.907 0 1.942.222 2.363.541-.195 2.741-2.655 5.483-6.441 5.483H8.714Z'}
        = t[:support_paypal]
