#!/usr/bin/env ruby
# frozen_string_literal: true

require 'mini_magick'
require 'optparse'

options = {
  quality:    80,
  max_width:  nil,
  strip:      true,
  thumb_only: nil,
  thumb_name: 'thumb.webp',
}

OptionParser.new do |opts|
  opts.banner = "Usage: bin/convert_to_webp [options] <image> [images...]\n\n" \
                "Converts images to WebP for web use.\n\n"

  opts.on('-q', '--quality N',      Integer, "WebP quality 1-100 (default: #{options[:quality]})")          { |v| options[:quality] = v }
  opts.on('-w', '--max-width N',    Integer, 'Resize to fit within this width (preserves ratio)')           { |v| options[:max_width] = v }
  opts.on('-t', '--thumb-only WxH', String,  'Write a WxH (or NxN square) crop to thumb.webp only')        { |v| options[:thumb_only] = v }
  opts.on('-n', '--thumb-name NAME', String, 'Output filename for --thumb-only (default: thumb.webp)')      { |v| options[:thumb_name] = v }
  opts.on('--[no-]strip',                    'Strip EXIF/metadata (default: yes)')                          { |v| options[:strip] = v }
  opts.on('-h', '--help')                    { puts opts; exit }
end.parse!

if ARGV.empty?
  warn "Error: no input files provided. Run with --help for usage."
  exit 1
end

def format_bytes(n)
  return "#{n} B"                       if n < 1_024
  return "#{(n / 1_024.0).round(1)} KB" if n < 1_048_576
  "#{(n / 1_048_576.0).round(1)} MB"
end

def parse_dimensions(spec)
  if spec =~ /\A(\d+)x(\d+)\z/i
    [$1.to_i, $2.to_i]
  elsif spec =~ /\A(\d+)\z/
    n = $1.to_i
    [n, n]
  else
    raise ArgumentError, "invalid dimensions '#{spec}' — use N or WxH"
  end
end

failures = 0

ARGV.each do |input|
  unless File.exist?(input)
    warn "  skip    #{input}  (not found)"
    failures += 1
    next
  end

  if options[:thumb_only]
    w, h       = parse_dimensions(options[:thumb_only])
    out_name   = options[:thumb_name]
    thumb_path = File.join(File.dirname(input), out_name)

    begin
      image = MiniMagick::Image.open(input)
      image.combine_options do |c|
        c.thumbnail "#{w}x#{h}^"
        c.gravity   'center'
        c.extent    "#{w}x#{h}"
      end
      image.strip if options[:strip]
      image.format 'webp'
      image.quality options[:quality].to_s
      image.write thumb_path

      puts "  #{File.basename(input).ljust(32)}→  #{out_name}  (#{w}×#{h})"
    rescue => e
      warn "  fail    #{input}  #{e.message}"
      failures += 1
    end

    next
  end

  output = File.join(File.dirname(input), "#{File.basename(input, '.*')}.webp")

  begin
    image = MiniMagick::Image.open(input)
    orig_w = image.width
    orig_h = image.height
    will_resize = options[:max_width] && orig_w > options[:max_width]

    if will_resize
      image.resize "#{options[:max_width]}x>"
    end

    image.strip if options[:strip]
    image.format 'webp'
    image.quality options[:quality].to_s
    image.write output

    src  = File.size(input)
    dst  = File.size(output)
    diff = ((1 - dst.to_f / src) * 100).round(1)
    sign = diff >= 0 ? "-#{diff}%" : "+#{diff.abs}%"

    if will_resize
      out_image = MiniMagick::Image.open(output)
      dim = "#{orig_w}×#{orig_h} → #{out_image.width}×#{out_image.height}"
    else
      dim = "#{orig_w}×#{orig_h}"
    end

    puts "  #{File.basename(input).ljust(32)}→  #{File.basename(output)}  " \
         "(#{format_bytes(src)} → #{format_bytes(dst)}, #{sign}, #{dim})"
  rescue => e
    warn "  fail    #{input}  #{e.message}"
    failures += 1
  end
end

exit(failures > 0 ? 1 : 0)
