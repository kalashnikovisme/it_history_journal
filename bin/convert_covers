#!/usr/bin/env bash
set -uo pipefail

mapfile -t covers < <(find articles \( -name "cover.png" -o -name "cover.jpg" \) | sort)

if [ ${#covers[@]} -eq 0 ]; then
  echo "No cover.png or cover.jpg files found in articles/."
  exit 0
fi

echo "Found ${#covers[@]} cover file(s):"
printf '  %s\n' "${covers[@]}"
echo

if bundle exec ruby bin/convert_to_webp "${covers[@]}"; then
  echo
  echo "Removing original files..."
  for f in "${covers[@]}"; do
    rm -f "$f"
    echo "  removed  $f"
  done
else
  echo
  echo "Some conversions failed. Removing only successfully converted files..."
  failed=0
  for f in "${covers[@]}"; do
    ext="${f##*.}"
    webp="${f%.$ext}.webp"
    if [ -f "$webp" ]; then
      rm -f "$f"
      echo "  removed  $f"
    else
      echo "  kept     $f  (conversion failed)"
      failed=1
    fi
  done
  exit $failed
fi
