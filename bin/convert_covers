#!/usr/bin/env bash
set -uo pipefail

# Phase 1: convert any non-WebP covers to cover.webp and remove the originals
mapfile -t covers < <(find articles \( -name "cover.png" -o -name "cover.jpg" -o -name "cover.jpeg" \) | sort)

if [ ${#covers[@]} -gt 0 ]; then
  echo "Found ${#covers[@]} cover file(s) to convert:"
  printf '  %s\n' "${covers[@]}"
  echo

  if bundle exec ruby bin/convert_to_webp "${covers[@]}"; then
    echo
    echo "Removing original files..."
    for f in "${covers[@]}"; do
      rm -f "$f"
      echo "  removed  $f"
    done
  else
    echo
    echo "Some conversions failed. Removing only successfully converted files..."
    failed=0
    for f in "${covers[@]}"; do
      ext="${f##*.}"
      webp="${f%.$ext}.webp"
      if [ -f "$webp" ]; then
        rm -f "$f"
        echo "  removed  $f"
      else
        echo "  kept     $f  (conversion failed)"
        failed=1
      fi
    done
    exit $failed
  fi
else
  echo "No cover.png / cover.jpg / cover.jpeg files found — skipping conversion."
fi

# Phase 2: generate 192×192 thumbnails and 576×384 hero images from cover.webp
echo
mapfile -t webp_covers < <(find articles -name "cover.webp" | sort)

if [ ${#webp_covers[@]} -eq 0 ]; then
  echo "No cover.webp files found — skipping thumbnail generation."
  exit 0
fi

missing_thumbs=()
missing_heroes=()
for f in "${webp_covers[@]}"; do
  dir="$(dirname "$f")"
  [ ! -f "$dir/thumb.webp" ] && missing_thumbs+=("$f")
  [ ! -f "$dir/hero.webp"  ] && missing_heroes+=("$f")
done

if [ ${#missing_thumbs[@]} -gt 0 ]; then
  echo "Generating list thumbnails (192×192) for ${#missing_thumbs[@]} cover(s):"
  bundle exec ruby bin/convert_to_webp --thumb-only 192 "${missing_thumbs[@]}"
else
  echo "All list thumbnails already exist — skipping."
fi

echo
if [ ${#missing_heroes[@]} -gt 0 ]; then
  echo "Generating hero images (576×384) for ${#missing_heroes[@]} cover(s):"
  bundle exec ruby bin/convert_to_webp --thumb-only 576x384 --thumb-name hero.webp "${missing_heroes[@]}"
else
  echo "All hero images already exist — skipping."
fi
