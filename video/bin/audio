#!/usr/bin/env ruby
# frozen_string_literal: true

require "video"
require "colorize"

def usage
  puts "Usage: audio <article_folder>"
  puts
  puts "  audio articles/ru/jun/21/tim_bray_was_born"
  puts
  puts "Options:"
  puts "  --force-text    Regenerate narration.txt even if it exists"
  puts "  --force-audio   Regenerate narration.mp3 even if it exists"
  exit 1
end

argv = ARGV.dup
force_text  = argv.delete("--force-text")
force_audio = argv.delete("--force-audio")
no_upload   = argv.delete("--no-upload")

article_folder = argv.shift
usage if article_folder.nil? || article_folder.empty?

unless File.directory?(article_folder)
  $stderr.puts "[audio] ERROR: Article folder not found: #{article_folder}".red
  exit 1
end

begin
  puts "[audio] Loading article...".cyan
  info = Video::ArticleLoader.load(article_folder)
  puts "[audio] #{info[:title]}".cyan

  paths  = Video::OutputPaths.new(info)
  client = Video::OpenAIClient.new

  # Narration — reuse if exists
  generator = Video::ScriptGenerator.new(info, paths, client)
  if File.exist?(paths.narration_txt) && !force_text
    puts "[audio] Reusing #{paths.narration_txt}".yellow
    narration = File.read(paths.narration_txt)
  else
    puts "[audio] Generating narration...".cyan
    narration = generator.generate(force: true)
    puts "[audio] Narration saved to #{paths.narration_txt}".green
  end

  # Audio — reuse if exists
  audio_gen = Video::AudioGenerator.new(paths, client)
  if File.exist?(paths.narration_mp3) && !force_audio
    puts "[audio] Reusing #{paths.narration_mp3}".yellow
    duration = audio_gen.probe_duration(paths.narration_mp3)
    puts "[audio] Duration: #{duration.round(1)}s".yellow
  else
    puts "[audio] Generating audio (TTS)...".cyan
    duration = audio_gen.generate(narration, force: true)
    puts "[audio] Done! #{duration.round(1)}s → #{paths.narration_mp3}".green
  end

  if no_upload
    puts "[audio] Upload skipped (--no-upload).".yellow
  elsif Video::DriveUploader.configured?
    puts "[audio] Uploading to Google Drive...".cyan
    uploader = Video::DriveUploader.new
    links    = uploader.upload(info, paths)
    puts "[audio] MP3 → #{links[:mp3]}".green if links[:mp3]
  else
    puts "[audio] Google Drive not configured — skipping upload.".yellow
  end

rescue => e
  $stderr.puts "[audio] ERROR: #{e.message}".red
  $stderr.puts e.backtrace.first(5).join("\n").red if ENV["DEBUG"]
  exit 1
end
