#!/usr/bin/env ruby
# frozen_string_literal: true

require "video"
require "colorize"
require "json"

def print_youtube_summary(youtube)
  bar = "─" * 60
  puts bar.cyan
  puts "  YouTube Metadata".cyan.bold
  puts bar.cyan
  puts "  Title:".bold
  puts "    #{youtube.fetch('title')}"
  puts ""
  puts "  Description:".bold
  youtube.fetch("description").each_line { |l| puts "    #{l.chomp}" }
  puts ""
  puts "  Tags:".bold
  puts "    #{youtube.fetch('tags').join(', ')}"
  puts bar.cyan
end

def usage
  puts "Usage: video [scenario] <article_folder>"
  puts "       video send <article_folder>"
  puts "       video part <name> <article_folder>"
  puts
  puts "  video articles/ru/jun/21/tim_bray_was_born          # full pipeline"
  puts "  video scenario articles/ru/jun/21/tim_bray_was_born # narration + scenes.json only"
  puts "  video send articles/ru/jun/21/tim_bray_was_born     # send video + metadata to Telegram"
  puts "  video part calendar articles/ru/jun/21/tim_bray_was_born # calendar only, no audio"
  puts
  puts "Options:"
  puts "  --force-text    Regenerate narration.txt even if it exists"
  puts "  --force-audio   Regenerate narration.mp3 even if it exists"
  puts "  --force-scenes  Regenerate platform scene files even if they exist"
  puts "  --force-youtube Regenerate YouTube title, description, and tags"
  puts "  --verbose       Show ffmpeg output during video composition"
  exit 1
end

argv = ARGV.dup
force_text    = argv.delete("--force-text")
force_audio   = argv.delete("--force-audio")
force_scenes  = argv.delete("--force-scenes")
force_youtube = argv.delete("--force-youtube")
no_upload     = argv.delete("--no-upload")
verbose       = argv.delete("--verbose")

usage if argv.empty?

scenario_only = false
send_only = false
part_name = nil
if argv[0] == "scenario"
  scenario_only = true
  argv.shift
elsif argv[0] == "send"
  send_only = true
  argv.shift
elsif argv[0] == "part"
  argv.shift
  part_name = argv.shift
  usage unless Video::PartRenderer::PARTS.key?(part_name)
end

article_folder = argv.shift
usage if article_folder.nil? || article_folder.empty?

unless File.directory?(article_folder)
  $stderr.puts "[video] ERROR: Article folder not found: #{article_folder}".red
  exit 1
end

begin
  puts "[video] Loading article...".cyan
  info = Video::ArticleLoader.load(article_folder)
  puts "[video] #{info[:title]}".cyan

  paths  = Video::OutputPaths.new(info)

  if send_only
    raise "Video metadata not found: #{paths.metadata_json}" unless File.exist?(paths.metadata_json)

    video_paths = Video::FfmpegComposer::PLATFORMS.keys.each_with_object({}) do |platform, h|
      path = paths.platform_mp4(platform)
      raise "Platform video not found: #{path}" unless File.exist?(path)
      h[platform] = path
    end

    metadata = JSON.parse(File.read(paths.metadata_json))
    youtube = metadata.fetch("youtube") { raise "YouTube metadata not found in #{paths.metadata_json}" }
    puts "[video] Sending #{video_paths.size} videos and YouTube metadata to Telegram...".cyan
    Video::TelegramNotifier.new.deliver(video_paths, youtube)
    puts "[video] Telegram delivery complete.".green
    exit 0
  end

  if part_name
    puts "[video] Rendering #{part_name} without audio...".cyan
    output = Video::PartRenderer.new(info, paths).render(part_name)
    puts "[video] Done! → #{output}".green
    exit 0
  end

  client = Video::OpenAIClient.new

  # Probe sample durations up front — needed for CTA timing in both scenario and full pipeline
  sample_durations    = Video::FfmpegComposer.probe_sample_durations
  max_sample_duration = sample_durations.values.max

  # Narration — reuse if exists
  generator = Video::ScriptGenerator.new(info, paths, client)
  if File.exist?(paths.narration_txt) && !force_text
    puts "[video] Reusing #{paths.narration_txt}".yellow
    narration = File.read(paths.narration_txt)
  else
    puts "[video] Generating narration...".cyan
    narration = generator.generate(force: true)
    puts "[video] Narration saved to #{paths.narration_txt}".green
  end

  planner = Video::ScenePlanner.new(info, paths)

  if scenario_only
    scenes, reused = planner.plan(narration, nil, sample_durations: sample_durations, force: force_scenes)
    if reused
      puts "[video] Reusing platform scene files.".yellow
    else
      puts "[video] Platform scene files written.".green
    end
    youtube_generator = Video::YoutubeMetadataGenerator.new(info, paths, client)
    youtube, youtube_reused = youtube_generator.generate(narration, force: force_youtube)
    puts youtube_reused ? "[video] Reusing YouTube metadata.".yellow : "[video] YouTube metadata saved.".green
    print_youtube_summary(youtube)
    puts "[video] Scenario mode — done.".green
    exit 0
  end

  # Audio — reuse if exists
  audio_gen = Video::AudioGenerator.new(paths, client)
  if File.exist?(paths.narration_mp3) && !force_audio
    puts "[video] Reusing #{paths.narration_mp3}".yellow
    duration = audio_gen.probe_duration(paths.narration_mp3)
  else
    puts "[video] Generating audio (TTS)...".cyan
    duration = audio_gen.generate(narration, force: true)
    puts "[video] Audio: #{duration.round(1)}s → #{paths.narration_mp3}".green
  end

  MAX_DURATION = 25.0
  HARD_LIMIT   = 35.0
  if duration > HARD_LIMIT
    raise "Audio is #{duration.round(1)}s — exceeds #{HARD_LIMIT}s hard limit. " \
          "Regenerate a shorter narration with --force-text."
  elsif duration > MAX_DURATION
    puts "[video] Warning: audio is #{duration.round(1)}s (target ≤#{MAX_DURATION}s).".yellow
  end

  # Scenes — write/reuse platform scene files
  scenes, reused = planner.plan(narration, duration, sample_durations: sample_durations, force: force_scenes)
  if reused
    puts "[video] Reusing platform scene files.".yellow
  else
    puts "[video] Platform scene files written (CTA at #{duration.round(1)}s).".green
  end

  youtube_generator = Video::YoutubeMetadataGenerator.new(info, paths, client)
  youtube, youtube_reused = youtube_generator.generate(narration, force: force_youtube)
  puts youtube_reused ? "[video] Reusing YouTube metadata.".yellow : "[video] YouTube metadata saved.".green

  # Render: narration + CTA in one pass; total length covers the longest sample
  total_recording_duration = duration + max_sample_duration
  puts "[video] Rendering browser frames (#{total_recording_duration.round(1)}s total)...".cyan
  renderer = Video::Renderer.new(info, paths, verbose: verbose)
  renderer.render(scenes, total_recording_duration)
  puts "[video] Browser recording saved to #{paths.browser_recording_webm}".green

  puts "[video] Composing platform videos...".cyan
  composer = Video::FfmpegComposer.new(paths, verbose: verbose)
  results  = composer.compose_all
  results.each { |platform, path| puts "[video] Done → #{path}".green }

  if no_upload
    puts "[video] Upload skipped (--no-upload).".yellow
  elsif Video::DriveUploader.configured?
    puts "[video] Uploading to Google Drive...".cyan
    uploader = Video::DriveUploader.new
    links    = uploader.upload(info, paths)
    puts "[video] MP3 → #{links[:mp3]}".green if links[:mp3]
    results.each_key do |platform|
      puts "[video] #{platform} → #{links[platform.to_sym]}".green if links[platform.to_sym]
    end
  else
    puts "[video] Google Drive not configured — skipping upload.".yellow
  end

  print_youtube_summary(youtube)

rescue => e
  $stderr.puts "[video] ERROR: #{e.message}".red
  $stderr.puts e.backtrace.first(5).join("\n").red if ENV["DEBUG"]
  exit 1
end
